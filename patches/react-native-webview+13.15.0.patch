index 0000000..5f5916a
--- /dev/null
+++ b/node_modules/react-native-webview/android/src/main/java/com/reactnativecommunity/webview/events/TopFileDownloadEvent.kt
@@ -0,0 +1,33 @@
+package com.reactnativecommunity.webview.events
+
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.WritableMap
+import com.facebook.react.uimanager.events.Event
+import com.facebook.react.uimanager.events.RCTEventEmitter
+
+/**
+ * Event emitted when the WebView triggers a file download (Content-Disposition:
+ * attachment / unrecognized binary). HireScope patches the DownloadListener to
+ * emit this instead of enqueuing to the system DownloadManager, so the JS layer
+ * can fail the in-flight scrape fast and record a blocked_download.
+ */
+class TopFileDownloadEvent(viewId: Int, downloadUrl: String) :
+    Event<TopFileDownloadEvent>(viewId) {
+  companion object {
+    const val EVENT_NAME = "topFileDownload"
+  }
+
+  private val mEventData: WritableMap = Arguments.createMap().apply {
+    putString("downloadUrl", downloadUrl)
+  }
+
+  override fun getEventName(): String = EVENT_NAME
+
+  override fun canCoalesce(): Boolean = false
+
+  override fun getCoalescingKey(): Short = 0
+
+  override fun dispatch(rctEventEmitter: RCTEventEmitter) {
+    rctEventEmitter.receiveEvent(viewTag, EVENT_NAME, mEventData)
+  }
+}
